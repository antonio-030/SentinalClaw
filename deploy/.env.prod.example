# ============================================================
# SentinelClaw — Produktions-Umgebungsvariablen
# ============================================================
# Kopiere diese Datei als .env.prod und fülle die Werte aus:
#   cp .env.prod.example .env.prod
#
# ACHTUNG: .env.prod wird NICHT committed (siehe .gitignore)
# ============================================================

# --- PFLICHT: Sicherheit ---
# JWT-Secret (mind. 32 Zeichen, keine Platzhalter!)
# Generieren: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SENTINEL_JWT_SECRET=DEIN_JWT_SECRET_HIER

# Erlaubte Scan-Ziele (CIDR oder Komma-getrennte IPs/Domains)
SENTINEL_ALLOWED_TARGETS=10.10.10.0/24

# Debug-Modus (false = Produktion, deaktiviert /docs und /redoc)
SENTINEL_DEBUG=false

# --- NemoClaw: LLM-Provider-Konfiguration ---
# Provider: claude (Anthropic), azure (Azure OpenAI), ollama (lokal)
NEMOCLAW_LLM_PROVIDER=claude

# API-Key für den gewählten Provider (bei ollama nicht nötig)
NEMOCLAW_LLM_API_KEY=

# --- SentinelClaw: API-Konfiguration ---
# LLM-Routing über NemoClaw-Gateway (Standard, nicht ändern)
SENTINEL_LLM_PROVIDER=nemoclaw

# Erlaubte CORS-Origins (Komma-getrennt, z.B. https://sentinel.firma.de)
SENTINEL_CORS_ORIGINS=https://localhost

# --- Optional: Datenbank ---
# Pfad zur SQLite-Datenbank (Standard: data/sentinelclaw.db)
# SENTINEL_DB_PATH=data/sentinelclaw.db

# --- Optional: Logging ---
# Log-Level: DEBUG, INFO, WARNING, ERROR (Standard: INFO)
# SENTINEL_LOG_LEVEL=INFO

# --- Optional: Scan-Limits ---
# SENTINEL_SANDBOX_TIMEOUT=300
# SENTINEL_MAX_CONCURRENT_SCANS=1
# SENTINEL_LLM_MAX_TOKENS_PER_SCAN=50000
